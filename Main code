═══════════════════════════════════════════════ */
function buildBrowse(){
  const grid=document.getElementById('browse-grid');grid.innerHTML='';
  WORDS.forEach(wobj=>{
    const card=document.createElement('div');
    card.className='wcard'+(isKnown(wobj.w)?' known':'');
    card.dataset.word=wobj.w;
    const colHtml=wobj.col.map(c=>`<div>· ${c}</div>`).join('');
    card.innerHTML=`
      <button class="known-btn" onclick="toggleKC('${esc(wobj.w)}',this)">✓</button>
      <div class="w-top"><span class="w-en">${wobj.w}</span><span class="w-pos">${wobj.pos}</span></div>
      <div class="w-vi">${wobj.vi}</div>
      <div class="w-en-def">${wobj.en}</div>
      ${wobj.col.length?`<div class="w-col-label">Collocations</div><div class="w-col">${colHtml}</div>`:''}`;
    grid.appendChild(card);
  });
  updateStats();
}

function toggleKC(w,btn){
  setKnown(w,!isKnown(w));
  btn.closest('.wcard').classList.toggle('known',isKnown(w));
}

function filterWords(q){
  const ql=q.toLowerCase();
  document.querySelectorAll('.wcard').forEach(card=>{
    const w=card.dataset.word;
    const wobj=WORDS.find(x=>x.w===w);
    const match=!ql||w.toLowerCase().includes(ql)||wobj.vi.toLowerCase().includes(ql)||wobj.en.toLowerCase().includes(ql);
    card.style.display=match?'':'none';
  });
}

/* ═══════════════════════════════════════════════
   FLASH
═══════════════════════════════════════════════ */
let fQ=[],fI=0,fFlip=false,fRes={},fFilt='all';
function getPool(){let p=[...WORDS];if(fFilt==='unknown')p=p.filter(w=>!isKnown(w.w));if(fFilt==='known')p=p.filter(w=>isKnown(w.w));return shuffle(p);}
function setFF(f,btn){fFilt=f;document.querySelectorAll('.ff-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');startFlash();}
function startFlash(){fQ=getPool();fI=0;fFlip=false;fRes={};if(!fQ.length){document.getElementById('cf-word').textContent='Không có từ!';return;}buildFDots();showFC();}
function showFC(){
  if(fI>=fQ.length){document.getElementById('cf-word').textContent='🎉 Xong!';document.getElementById('cf-pos').textContent='';document.getElementById('card-inner').classList.remove('flipped');return;}
  const c=fQ[fI];fFlip=false;
  document.getElementById('card-inner').classList.remove('flipped');
  document.getElementById('cf-word').textContent=c.w;
  document.getElementById('cf-pos').textContent=c.pos;
  document.getElementById('cb-vi').textContent=c.vi;
  document.getElementById('cb-en').textContent=c.en;
  const colWrap=document.getElementById('cb-col-wrap');
  if(c.col&&c.col.length){
    document.getElementById('cb-col').innerHTML=c.col.map(x=>`<div>· ${x}</div>`).join('');
    colWrap.style.display='block';
  } else {colWrap.style.display='none';}
  document.getElementById('fc-curr').textContent=fI+1;
  document.getElementById('fc-total').textContent=fQ.length;
  updateFDots();
  document.getElementById('prog-fill').style.width=((fI+1)/fQ.length*100)+'%';
}
function flipCard(){fFlip=!fFlip;document.getElementById('card-inner').classList.toggle('flipped',fFlip);}
function flashAns(knew){const c=fQ[fI];fRes[c.w]=knew;setKnown(c.w,knew);updateFDots();flashNext();}
function flashNext(){fI++;showFC();}
function buildFDots(){const c=document.getElementById('flash-dots');c.innerHTML='';fQ.forEach((_,i)=>{const d=document.createElement('div');d.className='fdot';d.id=`fd-${i}`;d.onclick=()=>{fI=i;fFlip=false;showFC();};c.appendChild(d);});}
function updateFDots(){fQ.forEach((_,i)=>{const d=document.getElementById(`fd-${i}`);if(!d)return;d.className='fdot';if(i===fI)d.classList.add('curr');else if(fRes[fQ[i].w]===true)d.classList.add('knew');else if(fRes[fQ[i].w]===false)d.classList.add('forgot');});}

/* ═══════════════════════════════════════════════
   TEST
═══════════════════════════════════════════════ */
function switchTab(t,btn){
  document.querySelectorAll('.test-tab').forEach(b=>b.classList.remove('active'));btn.classList.add('active');
  document.getElementById('panel-learn').style.display=t==='learn'?'block':'none';
  document.getElementById('panel-review').style.display=t==='review'?'block':'none';
}

/* ── LEARN (manual next) ── */
let lQ=[],lI=0,lS=0,lAns=false;
function startLearn(){
  const pool=WORDS.filter(w=>!isKnown(w.w));
  document.getElementById('lsub').textContent=`${pool.length} từ chưa tích ✓`;
  if(!pool.length){document.getElementById('learn-body').innerHTML=`<div class="empty-state"><div class="big">🎉</div>Tất cả từ đã tích ✓<br>Sang <strong>Review nhanh</strong> để ôn lại.</div>`;document.getElementById('learn-result').classList.remove('show');return;}
  lQ=shuffle([...pool]).slice(0,Math.min(20,pool.length));lI=0;lS=0;lAns=false;
  document.getElementById('learn-result').classList.remove('show');document.getElementById('learn-body').innerHTML='';showLQ();
}
function showLQ(){
  if(lI>=lQ.length){showLResult();return;}
  const q=lQ[lI];
  const wrongs=shuffle(WORDS.filter(w=>w.w!==q.w)).slice(0,3);
  const opts=shuffle([{...q,c:true},...wrongs.map(w=>({...w,c:false}))]);
  lAns=false;
  const div=document.createElement('div');div.className='test-q';div.id='lq';
  div.innerHTML=`
    <span class="tq-label">Câu ${lI+1}/${lQ.length}</span>
    <div class="tq-prompt">Nghĩa tiếng Việt: <strong>${q.vi}</strong></div>
    <div style="font-size:.72rem;color:var(--muted);margin-bottom:.2rem">Từ tiếng Anh nào tương ứng?</div>
    <div class="test-opts">${opts.map(o=>`<button class="topt" onclick="ansL(${o.c},this,'${esc(q.w)}')">${o.w} <span style="font-size:.68rem;color:var(--muted)">${o.pos}</span></button>`).join('')}</div>
    <div class="test-fb" id="lfb"></div>
    <button class="test-next" id="lnext" onclick="nextL()">Tiếp theo →</button>`;
  document.getElementById('learn-body').innerHTML='';document.getElementById('learn-body').appendChild(div);
  document.getElementById('prog-fill').style.width=(lI/lQ.length*100)+'%';
}
function ansL(correct,btn,cw){
  if(lAns)return;lAns=true;
  document.querySelectorAll('#lq .topt').forEach(b=>b.disabled=true);
  const fb=document.getElementById('lfb');
  if(correct){
    btn.classList.add('correct');
    fb.innerHTML='✓ Chính xác!';fb.className='test-fb show ok';
    lS++;setKnown(cw,true);
  } else {
    btn.classList.add('wrong');
    document.querySelectorAll('#lq .topt').forEach(b=>{if(b.textContent.includes(cw))b.classList.add('correct');});
    const cobj=WORDS.find(w=>w.w===cw);
    fb.innerHTML=`✗ Sai. Đáp án: <strong>${cw}</strong> — <span style="color:var(--blue)">${cobj?cobj.vi:''}</span>`;
    fb.className='test-fb show bad';setKnown(cw,false);
  }
  document.getElementById('lnext').classList.add('show');
}
function nextL(){lAns=false;lI++;showLQ();}
function showLResult(){
  document.getElementById('learn-body').innerHTML='';
  const pct=Math.round(lS/lQ.length*100);
  document.getElementById('l-score').textContent=`${lS}/${lQ.length}`;
  document.getElementById('l-label').textContent=pct>=90?'Xuất sắc! 🏆':pct>=70?'Tốt lắm! 👍':pct>=50?'Ổn — ôn thêm nhé.':'Học lại nhiều hơn 📖';
  document.getElementById('learn-result').classList.add('show');
  document.getElementById('prog-fill').style.width='100%';
}

/* ── REVIEW (auto-advance 1.5s) ── */
let rQ=[],rI=0,rS=0,rAns=false,rT=null;
function startReview(){
  const pool=WORDS.filter(w=>isKnown(w.w));
  document.getElementById('rsub').textContent=`${pool.length} từ đã tích ✓`;
  if(!pool.length){document.getElementById('review-body').innerHTML=`<div class="empty-state"><div class="big">📌</div>Chưa tích ✓ từ nào<br>Vào <strong>Browse</strong> tích từ đã nhớ trước nhé.</div>`;document.getElementById('review-result').classList.remove('show');return;}
  rQ=shuffle([...pool]).slice(0,Math.min(20,pool.length));rI=0;rS=0;rAns=false;if(rT)clearTimeout(rT);
  document.getElementById('review-result').classList.remove('show');document.getElementById('review-body').innerHTML='';showRQ();
}
function showRQ(){
  if(rI>=rQ.length){showRResult();return;}
  const q=rQ[rI];
  const wrongs=shuffle(WORDS.filter(w=>w.w!==q.w)).slice(0,3);
  const opts=shuffle([{...q,c:true},...wrongs.map(w=>({...w,c:false}))]);
  rAns=false;
  const div=document.createElement('div');div.className='test-q';div.id='rq';
  div.innerHTML=`
    <span class="tq-label">Câu ${rI+1}/${rQ.length} <span style="font-size:.58rem;color:var(--accent);opacity:.7">· tự nhảy câu</span></span>
    <div class="tq-prompt">Nghĩa tiếng Việt: <strong>${q.vi}</strong></div>
    <div style="font-size:.72rem;color:var(--muted);margin-bottom:.2rem">Từ tiếng Anh nào tương ứng?</div>
    <div class="test-opts">${opts.map(o=>`<button class="topt" onclick="ansR(${o.c},this,'${esc(q.w)}')">${o.w} <span style="font-size:.68rem;color:var(--muted)">${o.pos}</span></button>`).join('')}</div>
    <div class="test-fb" id="rfb"></div>
    <div style="display:none" id="rcd"><div class="countdown-bar"><div class="countdown-fill" id="rcd-fill" style="width:100%"></div></div></div>`;
  document.getElementById('review-body').innerHTML='';document.getElementById('review-body').appendChild(div);
  document.getElementById('prog-fill').style.width=(rI/rQ.length*100)+'%';
}
function ansR(correct,btn,cw){
  if(rAns)return;rAns=true;
  document.querySelectorAll('#rq .topt').forEach(b=>b.disabled=true);
  const fb=document.getElementById('rfb');
  if(correct){
    btn.classList.add('correct');fb.innerHTML='✓ Chính xác!';fb.className='test-fb show ok';rS++;
  } else {
    btn.classList.add('wrong');
    document.querySelectorAll('#rq .topt').forEach(b=>{if(b.textContent.includes(cw))b.classList.add('correct');});
    const cobj=WORDS.find(w=>w.w===cw);
    fb.innerHTML=`✗ Sai. Đáp án: <strong>${cw}</strong> — <span style="color:var(--blue)">${cobj?cobj.vi:''}</span>`;
    fb.className='test-fb show bad';
  }
  const cd=document.getElementById('rcd'),fill=document.getElementById('rcd-fill');
  if(cd){cd.style.display='block';fill.style.transition='none';fill.style.width='100%';setTimeout(()=>{fill.style.transition='width 1.5s linear';fill.style.width='0%';},30);}
  rT=setTimeout(()=>{rAns=false;rI++;showRQ();},1500);
}
function showRResult(){
  document.getElementById('review-body').innerHTML='';
  const pct=Math.round(rS/rQ.length*100);
  document.getElementById('r-score').textContent=`${rS}/${rQ.length}`;
  document.getElementById('r-label').textContent=pct>=90?'Xuất sắc! Đã nắm vững 🏆':pct>=70?'Tốt! Vẫn nhớ được phần lớn 👍':'Cần ôn lại thêm.';
  document.getElementById('review-result').classList.add('show');
  document.getElementById('prog-fill').style.width='100%';
}

/* ═══════════════════════════════════════════════
   UTILS
═══════════════════════════════════════════════ */
function esc(s){return s.replace(/'/g,"\\'").replace(/"/g,'&quot;');}
function shuffle(a){const b=[...a];for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]];}return b;}

/* INIT */
buildBrowse();updateStats();renderAddedList();
document.getElementById('panel-review').style.display='none';
</script>

</body>
</html>