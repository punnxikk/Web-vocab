   STATE
═══════════════════════════════════════════════ */
let known={};
try{known=JSON.parse(localStorage.getItem('psyv_known')||'{}');}catch(e){}
function saveKnown(){try{localStorage.setItem('psyv_known',JSON.stringify(known));}catch(e){}}
function isKnown(w){return !!known[w];}
function setKnown(w,v){if(v)known[w]=true;else delete known[w];saveKnown();updateStats();}
function resetKnown(){known={};saveKnown();updateStats();buildBrowse();}
function updateStats(){
  const k=Object.keys(known).filter(x=>known[x]).length;
  document.getElementById('known-stat').textContent=k;
  document.getElementById('known-count').textContent=k;
  document.getElementById('unknown-count').textContent=WORDS.length-k;
  document.querySelectorAll('.wcard').forEach(c=>c.classList.toggle('known',isKnown(c.dataset.word)));
}

let isDark=true;
function toggleTheme(){
  isDark=!isDark;
  document.documentElement.setAttribute('data-theme',isDark?'dark':'light');
  document.getElementById('theme-btn').textContent=isDark?'🌙':'☀️';
}

function setMode(m,btn){
  document.querySelectorAll('.mbtn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('[id^="view-"]').forEach(v=>v.classList.remove('active'));
  document.getElementById('view-'+m).classList.add('active');
  if(m==='flash')startFlash();
  if(m==='test'){startLearn();startReview();}
}

/* ═══════════════════════════════════════════════
   ADD WORD
═══════════════════════════════════════════════ */
let userAdded = [];
try{ userAdded = JSON.parse(localStorage.getItem('psyv_added')||'[]'); }catch(e){}
// push existing user words into WORDS on load
userAdded.forEach(w=>{ if(!WORDS.find(x=>x.w===w.w)) WORDS.push(w); });

function addColRow(){
  const rows=document.getElementById('col-rows');
  const div=document.createElement('div');div.className='col-row';
  div.innerHTML=`<input class="form-input" placeholder="collocation..."><button class="col-row-btn" onclick="removeColRow(this)" title="Xoá">✕</button>`;
  rows.appendChild(div);
}
function removeColRow(btn){
  const row=btn.closest('.col-row');
  const rows=document.getElementById('col-rows');
  if(rows.querySelectorAll('.col-row').length>1) row.remove();
  else row.querySelector('input').value='';
}

function addWord(){
  const w=document.getElementById('inp-word').value.trim();
  const pos=document.getElementById('inp-pos').value.trim();
  const vi=document.getElementById('inp-vi').value.trim();
  const en=document.getElementById('inp-en').value.trim();
  if(!w||!pos||!vi||!en){ alert('Vui lòng điền đủ 4 trường bắt buộc (*)'); return; }
  if(WORDS.find(x=>x.w.toLowerCase()===w.toLowerCase())){
    alert(`"${w}" đã có trong bộ từ vựng rồi!`); return;
  }
  // collect collocations
  const cols=[...document.getElementById('col-rows').querySelectorAll('.col-row input')]
    .map(i=>i.value.trim()).filter(Boolean);
  const newWord={w,pos,vi,en,col:cols};
  WORDS.push(newWord);
  userAdded.push(newWord);
  try{localStorage.setItem('psyv_added',JSON.stringify(userAdded));}catch(e){}

  // clear form
  document.getElementById('inp-word').value='';
  document.getElementById('inp-pos').value='';
  document.getElementById('inp-vi').value='';
  document.getElementById('inp-en').value='';
  document.getElementById('col-rows').innerHTML=`<div class="col-row"><input class="form-input" placeholder="vd: be <em>resilient</em> in the face of..."><button class="col-row-btn" onclick="removeColRow(this)" title="Xoá">✕</button></div>`;

  // show success
  const suc=document.getElementById('add-success');suc.classList.add('show');setTimeout(()=>suc.classList.remove('show'),2500);

  // rebuild browse & added list
  buildBrowse();renderAddedList();updateStats();
}

function renderAddedList(){
  const ctr=document.getElementById('added-items');
  document.getElementById('added-count').textContent=userAdded.length;
  if(!userAdded.length){ctr.innerHTML='<div class="empty-added">Chưa có từ nào được thêm</div>';return;}
  ctr.innerHTML=userAdded.map((w,i)=>`
    <div class="added-item">
      <span class="ai-word">${w.w}</span>
      <span class="ai-pos">${w.pos}</span>
      <span class="ai-vi">${w.vi}</span>
      <button class="ai-del" onclick="deleteAdded(${i})" title="Xoá từ này">🗑</button>
    </div>`).join('');
}

function deleteAdded(i){
  const w=userAdded[i];
  userAdded.splice(i,1);
  const idx=WORDS.findIndex(x=>x.w===w.w);
  if(idx>-1)WORDS.splice(idx,1);
  delete known[w.w];saveKnown();
  try{localStorage.setItem('psyv_added',JSON.stringify(userAdded));}catch(e){}
  buildBrowse();renderAddedList();updateStats();
}

